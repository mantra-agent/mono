{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BACKEND_TARGET": "development",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "ios": {
        "simulator": false,
        "image": "macos-sequoia-15.6-xcode-16.4"
      }
    },
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BACKEND_TARGET": "production",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-16.4"
      }
    },
    "production": {
      "developmentClient": false,
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BACKEND_TARGET": "production"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-16.4"
      }
    }
  }
}
