# EAS builds are mobile-only. Keep repo/runtime ballast out of the upload.
# shared/ stays included because mobile Metro imports shared models from the repo root.

# VCS and dependency caches
.git/
.github/
node_modules/
**/node_modules/
mobile/node_modules/
mobile/.expo/
mobile/.expo-shared/
mobile/.gradle/
mobile/android/build/
mobile/ios/build/

